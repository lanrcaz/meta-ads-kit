# Crimson Meta Agent — Environment Variables
#
# Authentication is handled by social-cli (no API keys needed here).
# Run: social auth login

# Default ad account (optional — can also set via social-cli)
# META_AD_ACCOUNT=act_123456789

# --- Slack Integration (optional) ---
# Create a Slack app at https://api.slack.com/apps
# Required scopes: chat:write, channels:read, channels:history
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_TEAM_ID=T00000000

# --- ClickUp Integration (optional) ---
# Get your API token at https://app.clickup.com/settings/apps
# CLICKUP_API_TOKEN=pk_00000000_0000000000000000000000000000
