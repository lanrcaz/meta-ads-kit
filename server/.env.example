# Crimson Meta Agent — Server Environment Variables

# --- Required ---

# Anthropic API key (for Claude interpretation of reports)
ANTHROPIC_API_KEY=sk-ant-your-key

# --- Slack Integration ---
# Create app at https://api.slack.com/apps
# Enable Socket Mode, Events API, and add bot scopes:
#   chat:write, app_mentions:read, channels:history, channels:read, im:history
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_CHANNEL_ID=C00000000

# --- ClickUp Integration ---
# Get API token at https://app.clickup.com/settings/apps
CLICKUP_API_TOKEN=pk_your-token
CLICKUP_LIST_ID=your-list-id
CLICKUP_WEBHOOK_SECRET=your-webhook-secret

# --- Schedule ---
# Cron expression for daily briefing (default: 8am weekdays)
DAILY_CRON=0 8 * * 1-5

# --- Meta Ads ---
# Optional override (otherwise uses social-cli default)
# META_AD_ACCOUNT=act_123456789

# --- Server ---
PORT=3000
